import { HorizontalBox, VerticalBox } from "std-widgets.slint";

component ShellButton inherits Rectangle {
    in property <string> label;
    in property <color> fill-color;
    in property <color> stroke-color;
    in property <color> text-color;

    width: 132px;
    height: 38px;
    border-radius: 12px;
    background: fill-color;
    border-width: 1px;
    border-color: stroke-color;

    Text {
        text: label;
        color: text-color;
        font-size: 14px;
        font-weight: 600;
        font-family: "Inter";
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

component TabChip inherits Rectangle {
    in property <string> label;
    in property <bool> active;

    width: 108px;
    height: 34px;
    border-radius: 11px;
    background: active ? #23343D : #162028;
    border-width: 1px;
    border-color: active ? #3FBAC2 : #1F2A33;

    Text {
        text: label;
        color: active ? #E8ECEF : #A7B0B7;
        font-size: 13px;
        font-weight: 600;
        font-family: "Inter";
        horizontal-alignment: center;
        vertical-alignment: center;
        width: parent.width;
        height: parent.height;
    }
}

component MetricTile inherits Rectangle {
    in property <string> caption;
    in property <string> value;
    in property <string> meta;
    in property <color> accent;

    width: 176px;
    height: 112px;
    border-radius: 16px;
    background: #162028;
    border-width: 1px;
    border-color: #1F2A33;

    Rectangle { x: 0; y: 0; width: 4px; height: parent.height; background: accent; }

    VerticalBox {
        padding: 18px;
        spacing: 6px;

        Text { text: caption; color: #A7B0B7; font-size: 12px; font-family: "Inter"; }
        Text { text: value; color: #E8ECEF; font-size: 28px; font-weight: 700; font-family: "Inter"; }
        Text { text: meta; color: accent; font-size: 12px; font-family: "Inter"; }
    }
}

component MonitorRow inherits Rectangle {
    in property <string> channel;
    in property <string> score;
    in property <string> verdict;
    in property <string> linked;
    in property <color> accent;

    height: 48px;
    border-radius: 12px;
    background: #121B22;
    border-width: 1px;
    border-color: #1F2A33;

    Text { x: 16px; y: 15px; width: 170px; text: channel; color: #E8ECEF; font-size: 13px; font-weight: 600; font-family: "Inter"; }
    Text { x: 194px; y: 15px; width: 56px; text: score; color: #A7B0B7; font-size: 13px; font-family: "Inter"; }

    Rectangle {
        x: 258px;
        y: 10px;
        width: 116px;
        height: 28px;
        border-radius: 10px;
        background: #1A262E;
        border-width: 1px;
        border-color: accent;
        Text {
            text: verdict;
            color: accent;
            font-size: 12px;
            font-weight: 600;
            font-family: "Inter";
            horizontal-alignment: center;
            vertical-alignment: center;
            width: parent.width;
            height: parent.height;
        }
    }

    Text { x: parent.width - 66px; y: 15px; width: 44px; text: linked; color: #A7B0B7; font-size: 13px; horizontal-alignment: right; font-family: "Inter"; }
}

export component AetherModernWindow inherits Window {
    title: "Aether Slint Preview";
    width: 1480px;
    height: 920px;
    background: #0E141A;

